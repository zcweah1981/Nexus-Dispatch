{
  "version": "v8-r0",
  "scope": "smoke-contract-only",
  "non_goals": [
    "R1-R9 implementation",
    "production database migration",
    "daemon or worker behavior rewrite",
    "review/report/cron/WebUI implementation"
  ],
  "task_statuses": [
    "created",
    "dispatched",
    "running",
    "completion_pending",
    "review_pending",
    "completed",
    "retry_ready",
    "blocked",
    "dead_letter",
    "cancelled"
  ],
  "legacy_status_mapping": {
    "validating": "completion_pending",
    "review_spawned": "review_pending",
    "accepted": "running",
    "failed": "retry_ready_or_dead_letter"
  },
  "smoke_boundaries": {
    "db_initialization": "schema_or_migration_only",
    "production_db_dependency": false,
    "allowed_database_path": "os.tmpdir() per test run"
  }
}
