# Nexus Dispatch production/local template.
# Copy to .env and fill real values on the target host only.
# Do NOT commit .env or paste real token/chat_id into docs/issues/logs.

# ── Core API / DB ────────────────────────────────────────────────
NODE_ENV=production
PORT=8000
NEXUS_API_PORT=8000
NEXUS_WEBUI_PORT=3030
DATABASE_URL=file:/data/nexus.db

# API Server accepts API_AUTH_TOKEN first; Daemon uses PM_API_TOKEN.
# Keep both equal unless you deliberately put a gateway in front.
API_AUTH_TOKEN=replace-with-long-random-token
PM_API_TOKEN=replace-with-long-random-token
PM_API_URL=http://nexus-api:8000/api/v1

# Project scope for V8 Runtime API.
NEXUS_PROJECT_ID=nexus-dispatch
PROJECT_ID=nexus-dispatch
NEXUS_PROJECTS_BASE=/root/.hermes/projects
# Telegram/report visible body language is a project setting, not an agent setting.
# Default is zh-CN. Set en-US through Runtime API after project creation:
# PATCH /api/v1/runtime/projects/<project-id>/settings/visible-language {"visible_language":"en-US"}

# Daemon tuning.
TICK_INTERVAL=5000
DISPATCH_TIMEOUT=10000
RECOVERY_TIMEOUT_MINUTES=15

# ── Telegram visible delivery ───────────────────────────────────
# Per-agent bot delivery only. Use placeholders here; inject real bot tokens
# and chat IDs from the host secret store or an untracked .env.
# Example shape:
# AGENT_NOTIFICATIONS={"long-coder-1":{"bot_token":"<agent-bot-token>","chat_id":"<group-chat-id>"}}
AGENT_NOTIFICATIONS={}

# Optional reverse proxy / CORS notes are handled outside this app.
