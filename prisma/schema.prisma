// Nexus Dispatch System — Prisma Schema V7.5
// 全表重建：tasks 补字段、4 张新表、artifacts 扩展
// Task: nd-v75-t11 | Agent: long-coder-1

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Agent（执行 Agent 注册表） ────────────────────────────
model Agent {
  id             String   @id @default(uuid())
  agent_id       String   @unique // e.g. 'long-coder-1'
  endpoint       String   // Webhook url
  lane           String   // DEV, DESIGN, OPS, CONTENT
  dialect        String   // hermes, openclaw
  soul_prompt    String   // PM customized prompt
  tools_allowed  String   // JSON string of allowed tools
  status         String   @default("offline") // online, offline
  last_heartbeat DateTime?
  created_at     DateTime @default(now())

  runs           Run[]

  @@map("nexus_agents")
}

// ─── Project（项目） ──────────────────────────────────────
model Project {
  id             String   @id @default(uuid())
  name           String   @unique
  status         String   @default("active") // active, archived
  pm_soul_prompt String?  // PM customized prompt
  channel_config String?  // JSON: Telegram/Discord configs
  created_at     DateTime @default(now())

  tasks          Task[]
  blueprints     ProjectBlueprint[]

  @@map("nexus_projects")
}

// ─── TaskGroup（任务分组，支持 DAG 编排） ────────────────────
model TaskGroup {
  id          String   @id @default(uuid())
  group_id    String   @unique // e.g. 'nd-v75-p1'
  name        String
  description String?
  status      String   @default("active") // active, completed, archived
  created_at  DateTime @default(now())

  tasks       Task[]

  @@map("task_groups")
}

// ─── Task（任务核心表） ────────────────────────────────────
model Task {
  id                 String   @id @default(uuid())
  project_id         String
  title              String
  objective          String
  lane_required      String
  status             String   @default("created") // created, dispatched, accepted, validating, completed, failed
  payload_schema     String?  // JSON Schema for payload validation
  payload            String?  // JSON: Detailed context
  proof_data         String?  // JSON: Artifacts from worker (Git SHA, Logs)
  ext_meta           String?  // JSON: Extended metadata

  // V7.5 新增字段
  task_group_id      String?  // FK → TaskGroup.id
  acceptance_criteria String? // JSON: 验收标准列表
  reviewer           String?  // e.g. 'pm-orchestrator-1'
  acceptance_mode    String?  // pm_audit, auto_verify, manual

  max_retries        Int      @default(3)
  retry_count        Int      @default(0)
  created_at         DateTime @default(now())

  project            Project     @relation(fields: [project_id], references: [id], onDelete: Cascade)
  taskGroup          TaskGroup?  @relation(fields: [task_group_id], references: [id], onDelete: SetNull)
  runs               Run[]
  outgoing_deps      TaskDependency[] @relation("TaskDepSource")
  incoming_deps      TaskDependency[] @relation("TaskDepTarget")

  @@index([status, lane_required])
  @@index([project_id])
  @@index([task_group_id])
  @@map("nexus_tasks")
}

// ─── TaskDependency（任务间依赖关系，DAG 拓扑） ─────────────
model TaskDependency {
  id              String   @id @default(uuid())
  task_id         String   // 源任务
  depends_on_id   String   // 依赖的目标任务
  dependency_type String   @default("blocks") // blocks, requires, related
  created_at      DateTime @default(now())

  source          Task     @relation("TaskDepSource", fields: [task_id], references: [id], onDelete: Cascade)
  target          Task     @relation("TaskDepTarget", fields: [depends_on_id], references: [id], onDelete: Cascade)

  @@unique([task_id, depends_on_id])
  @@index([task_id])
  @@index([depends_on_id])
  @@map("task_dependencies")
}

// ─── Run（执行流水） ──────────────────────────────────────
model Run {
  run_id          String    @id @default(uuid())
  task_id         String
  agent_id        String
  idempotency_key String    @unique
  status          String    @default("running") // running, success, failed
  error_stack     String?
  started_at      DateTime  @default(now())
  ended_at        DateTime?

  task            Task      @relation(fields: [task_id], references: [id], onDelete: Cascade)
  agent           Agent     @relation(fields: [agent_id], references: [id], onDelete: Cascade)
  artifacts       Artifact[]

  @@index([task_id, status])
  @@map("nexus_runs")
}

// ─── Artifact（产物表，V7.5 扩展） ────────────────────────
model Artifact {
  id            String   @id @default(uuid())
  run_id        String
  artifact_type String
  payload       String   // JSON
  created_at    DateTime @default(now())

  // V7.5 新增字段
  proof         String?  // JSON: 结构化验证证明
  path          String?  // 文件路径或 URL
  metadata_json String?  // JSON: 扩展元数据

  run           Run      @relation(fields: [run_id], references: [run_id], onDelete: Cascade)

  @@index([run_id])
  @@map("nexus_artifacts")
}

// ─── ProjectBlueprint（项目蓝图模板） ──────────────────────
model ProjectBlueprint {
  id          String   @id @default(uuid())
  project_id  String
  blueprint_id String @unique // e.g. 'bp-nexus-v75'
  name        String
  version     String   @default("1.0")
  schema_json String   // JSON: 蓝图 Schema 定义
  status      String   @default("draft") // draft, active, archived
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  project     Project  @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@index([project_id])
  @@map("project_blueprints")
}

// ─── FSMController（有限状态机控制器定义） ──────────────────
model FSMController {
  id              String   @id @default(uuid())
  controller_id   String   @unique // e.g. 'fsm-task-v1'
  name            String
  entity_type     String   // task, run, agent, project
  states_json     String   // JSON: 状态定义列表
  transitions_json String  // JSON: 转换规则列表
  initial_state   String   // 初始状态名
  config_json     String?  // JSON: 动态配置 (default_reviewer, dispatch_policy, etc.)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@index([entity_type])
  @@map("fsm_controllers")
}
